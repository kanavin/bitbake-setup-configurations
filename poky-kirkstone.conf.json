{
    "sources": {
        "poky": {
            "git-remote": {
                "remotes": {
                    "origin": {
                        "uri": "git://git.yoctoproject.org/poky"
                    }
                },
                "rev": "kirkstone"
            },
            "path": "poky"
        }
